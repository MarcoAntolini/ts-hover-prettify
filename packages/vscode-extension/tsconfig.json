{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"lib": ["ES2020"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"rootDir": "src",
		"types": ["node", "vscode"]
	},
	"include": ["src/extension.ts", "src/workspace-types.ts", ".vscode/ts-hover-prettify.d.ts"],
	"exclude": ["src/tsserver-plugin"]
}
