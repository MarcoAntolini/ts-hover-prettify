{
	"name": "ts-hover-prettify-vscode",
	"private": true,
	"displayName": "TS Hover Prettify",
	"description": "Prettier TypeScript hover tooltips via the Prettify utility type (zero-config)",
	"version": "0.2.1",
	"publisher": "marcoantolini",
	"license": "MIT",
	"repository": "https://github.com/MarcoAntolini/ts-hover-prettify",
	"homepage": "https://github.com/MarcoAntolini/ts-hover-prettify#readme",
	"icon": "icon.png",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": ["Other", "Programming Languages"],
	"activationEvents": [
		"onStartupFinished",
		"onLanguage:typescript",
		"onLanguage:typescriptreact"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"typescriptServerPlugins": [
			{
				"name": "ts-hover-prettify-plugin",
				"location": "./dist/tsserver-plugin",
				"enableForWorkspaceTypeScriptVersions": true,
				"enableForBundledTypeScriptVersions": true
			}
		]
	},
	"scripts": {
		"t-build": "node scripts/build.mjs",
		"t-lint": "tsc --noEmit -p tsconfig.json",
		"t-package": "pnpm run t-build && node -e \"require('node:fs').mkdirSync('build',{recursive:true})\" && vsce package --no-dependencies --out build/"
	},
	"dependencies": {
		"ts-hover-prettify": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^20.6.3",
		"@types/vscode": "^1.85.0",
		"@vscode/vsce": "^2.22.0",
		"esbuild": "^0.19.4",
		"typescript": "^5.2.2"
	}
}
